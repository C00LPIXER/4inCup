rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Championships - public read, authenticated or open write
    match /championships/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Players - public read, open write (registration)
    match /players/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Teams - public read, admin write
    match /teams/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Matches - public read, admin write
    match /matches/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
