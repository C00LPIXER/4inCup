rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Championships - public read, authenticated or open write
    match /championships/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Players - public read, open write (registration)
    match /players/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Teams - public read, admin write
    match /teams/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Matches - public read, admin write
    match /matches/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Admins - only authenticated users (both prod and test datasets)
    match /admins/{uid} {
      allow read, write: if request.auth != null;
    }

    match /test_admins/{uid} {
      allow read, write: if request.auth != null;
    }

    // Test dataset collections (mirror of prod, open for development)
    match /test_championships/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /test_players/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /test_teams/{docId} {
      allow read: if true;
      allow write: if true;
    }

    match /test_matches/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
